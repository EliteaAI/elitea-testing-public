# Elitea Test Automation — Environment Configuration
# Copy this file to .env.test and fill in your values.
#
# Target environment
ELITEA_URL=https://stage.elitea.ai
ELITEA_API_BASE=https://stage.elitea.ai/api/v2
ELITEA_PROJECT_ID=<your_project_id>

# Keycloak credentials (use username, NOT email)
TEST_USER_EMAIL=<keycloak_username>
TEST_USER_PASSWORD=<keycloak_password>

# Elitea API token (generated in Settings → API Keys)
ELITEA_API_TOKEN=<your_api_token>

# Toolkit tokens — tests that require these will auto-skip if not set
# GITHUB_TOKEN=ghp_...
# JIRA_API_KEY=...
# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_USERNAME=...

# Artifact toolkit tests (ELITEA-1327) — auto-skip if not set
# ARTIFACT_AGENT_ID=<id of agent with Artifact toolkit attached>
# ARTIFACT_BUCKET_NAME=<name of the artifact bucket the toolkit writes to>
